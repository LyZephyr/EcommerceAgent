ARK_API_KEY=your-api-key-here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/
ARK_MODEL=ep-20260514111645-lmgt2
EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
# Hugging Face 模型下载镜像（国内推荐 hf-mirror.com；直连官方可改为 https://huggingface.co）
HF_ENDPOINT=https://hf-mirror.com
# 设为 1 时仅使用本地缓存，不联网下载（首次 ingest 前须为 0）
HF_HUB_OFFLINE=0
TOP_K=5

# docker compose 将 MySQL 映射到本机 127.0.0.1:3306
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=ecommerce123
MYSQL_DATABASE=ecommerce_agent
